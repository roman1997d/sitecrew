<%- include('../partials/header', { seo: seo }) %>

<section class="section legal-page">
  <div class="site-container legal-page-inner">
    <p class="legal-eyebrow">Support</p>
    <h1>Contact SiteCrew</h1>
    <p class="legal-lead">Questions about accounts, jobs, privacy, or partnerships? Send us a message and we will respond as soon as possible.</p>

    <div class="contact-layout">
      <article class="contact-form-card">
        <h2>Send us a message</h2>
        <p>Fill in the form below and our team will get back to you within 2 business days.</p>

        <div class="contact-form-alert" id="contact-form-alert" hidden></div>

        <form id="contact-form" class="contact-form" novalidate>
          <div class="contact-form-grid">
            <label class="contact-form-field">
              <span>Your name</span>
              <input type="text" id="contact-name" name="name" required minlength="2" autocomplete="name" placeholder="Full name">
            </label>

            <label class="contact-form-field">
              <span>Email address</span>
              <input type="email" id="contact-email" name="email" required autocomplete="email" placeholder="you@example.com">
            </label>
          </div>

          <label class="contact-form-field">
            <span>Subject</span>
            <select id="contact-subject" name="subject" required>
              <option value="">Choose a topic</option>
              <option value="General support">General support</option>
              <option value="Worker account">Worker account</option>
              <option value="Company account">Company account</option>
              <option value="Billing and plans">Billing and plans</option>
              <option value="Privacy request">Privacy request</option>
              <option value="Partnership enquiry">Partnership enquiry</option>
              <option value="Other">Other</option>
            </select>
          </label>

          <label class="contact-form-field">
            <span>Message</span>
            <textarea id="contact-message" name="message" rows="6" required minlength="10" maxlength="5000" placeholder="Tell us how we can help"></textarea>
          </label>

          <div class="contact-recaptcha-wrap">
            <div class="g-recaptcha" data-sitekey="<%= recaptchaSiteKey %>"></div>
          </div>

          <button type="submit" class="btn-sc btn-sc-blue contact-form-submit" id="contact-form-submit">Send message</button>
        </form>
      </article>

      <div class="contact-side">
        <article class="contact-card">
          <h2>Email us directly</h2>
          <p>For quick enquiries you can also write to us at:</p>
          <a class="btn-sc btn-sc-outline" href="mailto:<%= contactEmail %>"><i class="bi bi-envelope"></i> <%= contactEmail %></a>
        </article>

        <article class="contact-card">
          <h2>Company plans</h2>
          <p>Questions about company subscriptions, billing, or onboarding your team.</p>
          <a class="btn-sc btn-sc-outline" href="/login?mode=register&role=company">Register as company</a>
        </article>

        <article class="contact-card">
          <h2>Workers</h2>
          <p>Ready to find your next site role? Create a profile and set your trade interests.</p>
          <a class="btn-sc btn-sc-outline" href="/login?mode=register&role=worker">Join as worker</a>
        </article>

        <div class="contact-note">
          <p><strong>Response times:</strong> We aim to reply within 2 business days.</p>
          <p>For urgent safety issues on site, always follow your employer's and site procedures first.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  window.SITECREW_API_BASE_URL = window.location.origin;
</script>
<script src="https://www.google.com/recaptcha/api.js" async defer></script>
<script src="/js/contact.js"></script>

<%- include('../partials/footer') %>
