<!DOCTYPE html>
<html lang="<%= dashboard.worker.languagePreference || 'en' %>">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/google-analytics') %>
  <%- include('../partials/cookie-script') %>
  <title><%= title %> | SiteCrew</title>
  <%- include('../partials/favicon') %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/dashboard.css" rel="stylesheet">
</head>
<body class="dash-body social-dash-body" data-worker-language="<%= dashboard.worker.languagePreference || '' %>">
  <div class="social-dashboard">
    <%- include('../components/dashboard/topbar', {
      worker: dashboard.worker,
      counts: dashboard.counts
    }) %>

    <div class="social-layout">
      <%- include('../components/dashboard/left-panel', {
        worker: dashboard.worker,
        pinnedCompanies: dashboard.pinnedCompanies
      }) %>

      <%- include('../components/dashboard/feed', {
        feedItems: dashboard.feedItems,
        stories: dashboard.stories,
        tradeInterests: dashboard.tradeInterests || []
      }) %>

      <%- include('../components/dashboard/right-panel', {
        notifications: dashboard.notifications,
        quickJobs: dashboard.quickJobs
      }) %>
    </div>

    <%- include('../components/dashboard/fab') %>
  </div>

  <%- include('../components/dashboard/worker-create-post-modal') %>

  <div class="story-viewer-overlay" id="storyViewer" aria-hidden="true">
    <div class="story-viewer" role="dialog" aria-modal="true" aria-labelledby="storyViewerCompany">
      <button type="button" class="story-viewer-close" id="closeStoryViewer" aria-label="Close story" data-i18n-attr="aria-label:story.close">
        <i class="bi bi-x-lg"></i>
      </button>
      <div class="story-viewer-header">
        <div class="story-viewer-avatar" id="storyViewerAvatar">S</div>
        <div>
          <h2 id="storyViewerCompany" data-i18n="story.companyStory">Company story</h2>
          <p id="storyViewerExpires" data-i18n="story.activeStory">Active story</p>
        </div>
      </div>
      <div class="story-viewer-media" id="storyViewerMedia">
        <span data-i18n="story.noImage">No story image</span>
      </div>
      <p class="story-viewer-caption" id="storyViewerCaption"></p>
    </div>
  </div>

  <div class="status-modal-overlay" id="statusModal" aria-hidden="true">
    <div class="status-modal" role="dialog" aria-modal="true" aria-labelledby="statusModalTitle">
      <h3 id="statusModalTitle" data-i18n="profile.changeStatus">Change status</h3>
      <div class="avail-toggles">
        <label class="avail-option active" data-status="available">
          <input type="radio" name="availabilityStatus" value="available" checked>
          <span class="avail-dot" style="background: var(--dash-green);"></span>
          <span data-i18n="availability.availableNow">Available Now</span>
        </label>
        <label class="avail-option" data-status="soon">
          <input type="radio" name="availabilityStatus" value="soon">
          <span class="avail-dot" style="background: var(--dash-yellow);"></span>
          <span data-i18n="availability.availableSoon">Available Soon</span>
        </label>
        <label class="avail-option" data-status="busy">
          <input type="radio" name="availabilityStatus" value="busy">
          <span class="avail-dot" style="background: var(--dash-red);"></span>
          <span data-i18n="availability.busy">Busy</span>
        </label>
      </div>
      <div class="status-modal-actions">
        <button type="button" class="btn-modal-cancel" id="cancelStatusBtn" data-i18n="profile.cancel">Cancel</button>
        <button type="button" class="btn-modal-save" id="saveStatusBtn" data-i18n="buttons.save">Save</button>
      </div>
    </div>
  </div>

  <div class="marketplace-ad-preview-overlay" id="marketplaceAdPreview" aria-hidden="true">
    <div class="marketplace-ad-preview" role="dialog" aria-modal="true" aria-labelledby="marketplaceAdPreviewCaption">
      <button
        type="button"
        class="marketplace-ad-preview-close"
        id="closeMarketplaceAdPreview"
        aria-label="Close image preview"
        data-i18n-attr="aria-label:marketplaceAd.previewClose"
      >
        <i class="bi bi-x-lg"></i>
      </button>
      <div class="marketplace-ad-preview-media" id="marketplaceAdPreviewMedia"></div>
      <p class="marketplace-ad-preview-caption" id="marketplaceAdPreviewCaption"></p>
    </div>
  </div>

  <%- include('../components/dashboard/find-job-modal', { tradeInterests: dashboard.tradeInterests || [] }) %>

  <%- include('../components/dashboard/worker-trade-interest-modal') %>

  <%- include('../partials/api-config') %>
  <script src="/js/worker-i18n.js"></script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
