<%- include('partials/header') %>

<!-- Hero -->
<section class="hero-home">
  <div class="hero-glow hero-glow-1"></div>
  <div class="hero-glow hero-glow-2"></div>
  <div class="hero-glow hero-glow-3"></div>
  <div class="hero-grid"></div>

  <div class="site-container hero-inner">
    <div class="hero-content">
      <div class="hero-badge">Live platform · 250+ jobs open now</div>
      <h1>Find construction workers &amp; jobs <span class="highlight">instantly</span></h1>
      <p class="hero-subtitle">Connect skilled tradespeople with companies in real time. No agencies. Direct hiring.</p>
      <div class="hero-cta">
        <a href="/login?mode=register&role=worker" class="btn-sc btn-sc-cta"><i class="bi bi-person-hard-hat"></i> Join as Worker</a>
        <a href="/login?mode=register&role=company" class="btn-sc btn-sc-glass"><i class="bi bi-building"></i> Join as Company</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat"><strong>1,200+</strong><span>Active workers</span></div>
        <div class="hero-stat"><strong>180+</strong><span>Companies</span></div>
        <div class="hero-stat"><strong>48h</strong><span>Avg. hire time</span></div>
      </div>
    </div>

    <div class="hero-visual">
      <div class="hero-card-float hero-card-main">
        <div class="card-trade">Dryliner · CSCS Required</div>
        <h4>Dryliners Needed</h4>
        <p class="card-loc"><i class="bi bi-geo-alt-fill"></i> Liverpool, UK</p>
        <div class="card-rate">£220<span style="font-size:14px;font-weight:500;color:#64748B">/day</span></div>
      </div>
      <div class="hero-card-float hero-card-side">
        <div class="icon-circle"><i class="bi bi-lightning-fill"></i></div>
        <p>12 workers matched in your area</p>
      </div>
    </div>
  </div>
</section>

<!-- How it works -->
<section class="section section-how" id="how-it-works">
  <div class="site-container">
    <div class="section-header">
      <span class="section-eyebrow">Simple process</span>
      <h2 class="section-title">How SiteCrew works</h2>
      <p class="section-desc">Two paths. One platform. Get started in minutes.</p>
    </div>
    <div class="row g-4">
      <div class="col-md-6">
        <div class="how-card how-card-worker">
          <div class="how-card-icon"><i class="bi bi-person-hard-hat"></i></div>
          <h3>For Workers</h3>
          <ul class="how-steps">
            <li><span class="step-num">1</span> Create your profile</li>
            <li><span class="step-num">2</span> Set your availability</li>
            <li><span class="step-num">3</span> Get hired</li>
          </ul>
        </div>
      </div>
      <div class="col-md-6">
        <div class="how-card how-card-company">
          <div class="how-card-icon"><i class="bi bi-building"></i></div>
          <h3>For Companies</h3>
          <ul class="how-steps">
            <li><span class="step-num">1</span> Post a job or project</li>
            <li><span class="step-num">2</span> Find matched workers</li>
            <li><span class="step-num">3</span> Hire instantly</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Latest Jobs -->
<section class="section section-jobs" id="jobs">
  <div class="site-container">
    <div class="section-header">
      <span class="section-eyebrow">Opportunities</span>
      <h2 class="section-title">Latest Jobs</h2>
      <p class="section-desc">Real roles. Real rates. Updated daily.</p>
    </div>
    <div class="row g-4 mb-5">
      <div class="col-md-4">
        <div class="job-card">
          <div class="job-card-header dryliner">
            <h4>Dryliners</h4>
            <div class="job-loc"><i class="bi bi-geo-alt"></i> Liverpool</div>
          </div>
          <div class="job-card-body">
            <div class="job-rate-big">£220<span style="font-size:16px;color:#64748B">/day</span></div>
            <span class="badge-live">Available Now</span>
            <a href="#" class="btn-sc btn-sc-blue btn-sc-sm mt-auto align-self-start">View job</a>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="job-card">
          <div class="job-card-header labourer">
            <h4>Labourers</h4>
            <div class="job-loc"><i class="bi bi-geo-alt"></i> Manchester</div>
          </div>
          <div class="job-card-body">
            <div class="job-rate-big">£180<span style="font-size:16px;color:#64748B">/day</span></div>
            <span class="badge-live">Available Now</span>
            <a href="#" class="btn-sc btn-sc-blue btn-sc-sm">View job</a>
          </div>
        </div>
      </div>
      <div class="col-md-4">
        <div class="job-card">
          <div class="job-card-header plasterer">
            <h4>Plasterers</h4>
            <div class="job-loc"><i class="bi bi-geo-alt"></i> Leeds · 3 months</div>
          </div>
          <div class="job-card-body">
            <div class="job-rate-big">£200<span style="font-size:16px;color:#64748B">/day</span></div>
            <a href="#" class="btn-sc btn-sc-blue btn-sc-sm">View job</a>
          </div>
        </div>
      </div>
    </div>
    <div class="text-center">
      <a href="#" class="btn-sc btn-sc-outline">View all jobs <i class="bi bi-arrow-right"></i></a>
    </div>
  </div>
</section>

<!-- Company updates -->
<section class="section section-companies" id="companies">
  <div class="site-container">
    <div class="section-header">
      <span class="section-eyebrow">Industry feed</span>
      <h2 class="section-title">Latest company updates</h2>
      <p class="section-desc">See what construction companies are working on right now.</p>
    </div>
    <div class="company-carousel" id="companyCarousel">
      <div class="company-carousel-controls">
        <button type="button" class="carousel-btn carousel-btn-prev" aria-label="Previous slide">
          <i class="bi bi-chevron-left"></i>
        </button>
        <button type="button" class="carousel-btn carousel-btn-next" aria-label="Next slide">
          <i class="bi bi-chevron-right"></i>
        </button>
      </div>
      <div class="company-carousel-viewport">
        <div class="company-carousel-track">
          <div class="company-carousel-slide">
            <div class="company-post">
              <div class="company-post-img img-1"><div class="company-avatar"><i class="bi bi-building"></i></div></div>
              <div class="company-post-body">
                <h5>Apex Construction</h5>
                <p>Starting 120-unit residential project in Liverpool — hiring 20+ trades.</p>
                <a href="#" class="btn-sc btn-sc-ghost btn-sc-sm">Follow company</a>
              </div>
            </div>
          </div>
          <div class="company-carousel-slide">
            <div class="company-post">
              <div class="company-post-img img-2"><div class="company-avatar"><i class="bi bi-building"></i></div></div>
              <div class="company-post-body">
                <h5>NorthBuild Ltd</h5>
                <p>Looking for 15 dryliners for a major Manchester commercial fit-out.</p>
                <a href="#" class="btn-sc btn-sc-ghost btn-sc-sm">Follow company</a>
              </div>
            </div>
          </div>
          <div class="company-carousel-slide">
            <div class="company-post">
              <div class="company-post-img img-3"><div class="company-avatar"><i class="bi bi-building"></i></div></div>
              <div class="company-post-body">
                <h5>Skyline Projects</h5>
                <p>New Leeds commercial project kicking off next week — multiple trades needed.</p>
                <a href="#" class="btn-sc btn-sc-ghost btn-sc-sm">Follow company</a>
              </div>
            </div>
          </div>
          <div class="company-carousel-slide">
            <div class="company-post">
              <div class="company-post-img img-4"><div class="company-avatar"><i class="bi bi-building"></i></div></div>
              <div class="company-post-body">
                <h5>Brickwell Group</h5>
                <p>Expanding Birmingham team — bricklayers and labourers wanted immediately.</p>
                <a href="#" class="btn-sc btn-sc-ghost btn-sc-sm">Follow company</a>
              </div>
            </div>
          </div>
          <div class="company-carousel-slide">
            <div class="company-post">
              <div class="company-post-img img-5"><div class="company-avatar"><i class="bi bi-building"></i></div></div>
              <div class="company-post-body">
                <h5>Metro Fit-Out</h5>
                <p>London office refurbishment starting Monday — electricians &amp; joiners needed.</p>
                <a href="#" class="btn-sc btn-sc-ghost btn-sc-sm">Follow company</a>
              </div>
            </div>
          </div>
          <div class="company-carousel-slide">
            <div class="company-post">
              <div class="company-post-img img-6"><div class="company-avatar"><i class="bi bi-building"></i></div></div>
              <div class="company-post-body">
                <h5>Coastal Developments</h5>
                <p>Brighton seafront project — plasterers and painters required for 6-month contract.</p>
                <a href="#" class="btn-sc btn-sc-ghost btn-sc-sm">Follow company</a>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="company-carousel-dots" role="tablist" aria-label="Company updates slides"></div>
    </div>
  </div>
</section>

<!-- Trust -->
<section class="section section-trust">
  <div class="site-container">
    <div class="section-header">
      <span class="section-eyebrow">Why SiteCrew</span>
      <h2 class="section-title">Built for the construction industry</h2>
    </div>
    <div class="trust-grid">
      <div class="trust-item">
        <div class="trust-icon t1"><i class="bi bi-patch-check-fill"></i></div>
        <h5>Verified Companies</h5>
        <p>Admin-approved employers only</p>
      </div>
      <div class="trust-item">
        <div class="trust-icon t2"><i class="bi bi-person-check-fill"></i></div>
        <h5>Verified Workers</h5>
        <p>Real profiles &amp; certificates</p>
      </div>
      <div class="trust-item">
        <div class="trust-icon t3"><i class="bi bi-chat-dots-fill"></i></div>
        <h5>Direct Communication</h5>
        <p>No agencies or middlemen</p>
      </div>
      <div class="trust-item">
        <div class="trust-icon t4"><i class="bi bi-lightning-fill"></i></div>
        <h5>Real-time Availability</h5>
        <p>Know who's free right now</p>
      </div>
    </div>
  </div>
</section>

<!-- Final CTA -->
<section id="register">
  <div class="cta-banner">
    <h2>Start working or hiring in minutes</h2>
    <p>Join thousands of tradespeople and companies already on SiteCrew.</p>
    <div class="hero-cta">
      <a href="/login?mode=register&role=worker" class="btn-sc btn-sc-cta">Join as Worker</a>
      <a href="/login?mode=register&role=company" class="btn-sc btn-sc-glass">Join as Company</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>
