<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/google-analytics') %>
  <%- include('../partials/cookie-script') %>
  <title>Reset password | SiteCrew</title>
  <%- include('../partials/favicon') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/login.css" rel="stylesheet">
</head>
<body>
  <div class="login-page">
    <div class="login-circle login-circle-1"></div>
    <div class="login-circle login-circle-2"></div>

    <a href="/login" class="login-back"><i class="bi bi-arrow-left"></i> Back to sign in</a>

    <div class="login-container">
      <div class="login-brand">
        <div class="login-brand-icon"><i class="bi bi-hammer"></i></div>
        <span class="login-brand-name">SiteCrew</span>
      </div>

      <p class="login-welcome">Secure reset</p>
      <h1 class="login-heading">Choose a new password</h1>
      <p class="login-subtitle" id="reset-password-subtitle">Enter your new password below.</p>

      <div class="auth-alert" id="password-reset-alert" hidden></div>

      <form id="reset-password-form" class="auth-form" hidden>
        <input type="hidden" id="reset-token" name="token" value="">

        <div class="login-field">
          <label for="reset-password">New password</label>
          <input type="password" id="reset-password" name="password" placeholder="New password" required minlength="8" autocomplete="new-password">
          <i class="bi bi-lock login-field-icon"></i>
        </div>

        <div class="login-field">
          <label for="reset-password-confirm">Confirm password</label>
          <input type="password" id="reset-password-confirm" name="passwordConfirm" placeholder="Confirm password" required minlength="8" autocomplete="new-password">
          <i class="bi bi-shield-lock login-field-icon"></i>
        </div>

        <button type="submit" class="login-btn">Reset password</button>
      </form>

      <p class="login-secondary-link">
        <a href="/forgot-password">Request a new reset link</a>
      </p>
    </div>
  </div>

  <%- include('../partials/api-config') %>
  <script src="/js/password-reset.js"></script>
</body>
</html>
