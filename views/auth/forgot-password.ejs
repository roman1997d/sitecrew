<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%- include('../partials/google-analytics') %>
  <%- include('../partials/cookie-script') %>
  <title>Forgot password | SiteCrew</title>
  <%- include('../partials/favicon') %>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/login.css" rel="stylesheet">
</head>
<body>
  <div class="login-page">
    <div class="login-circle login-circle-1"></div>
    <div class="login-circle login-circle-2"></div>

    <a href="/login" class="login-back"><i class="bi bi-arrow-left"></i> Back to sign in</a>

    <div class="login-container">
      <div class="login-brand">
        <div class="login-brand-icon"><i class="bi bi-hammer"></i></div>
        <span class="login-brand-name">SiteCrew</span>
      </div>

      <p class="login-welcome">Account recovery</p>
      <h1 class="login-heading">Forgot password?</h1>
      <p class="login-subtitle">Enter your email and we will send you a reset link.</p>

      <div class="auth-alert" id="password-reset-alert" hidden></div>

      <form id="forgot-password-form" class="auth-form">
        <div class="login-field">
          <label for="forgot-email">Email</label>
          <input type="email" id="forgot-email" name="email" placeholder="Email" required autocomplete="email">
          <i class="bi bi-envelope login-field-icon"></i>
        </div>

        <button type="submit" class="login-btn">Send reset link</button>
      </form>

      <p class="login-secondary-link">
        Remembered your password? <a href="/login">Sign in</a>
      </p>
    </div>
  </div>

  <%- include('../partials/api-config') %>
  <script src="/js/password-reset.js"></script>
</body>
</html>
