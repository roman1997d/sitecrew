<aside class="company-sidebar">
  <a href="#dashboard" class="company-sidebar-logo" data-company-nav="dashboard">
    <span class="company-brand-mark" aria-hidden="true">S</span>
    <span class="company-brand-text">Site<span>Crew</span></span>
  </a>

  <nav class="company-nav" aria-label="Company navigation">
    <a href="#dashboard" class="active" data-company-nav="dashboard"><i class="bi bi-grid-1x2-fill"></i> Dashboard</a>
    <a href="#dashboard/active-jobs" data-company-nav="dashboard" data-company-focus="active-jobs"><i class="bi bi-briefcase"></i> Jobs</a>
    <a href="#dashboard/applicants" data-company-nav="dashboard" data-company-focus="applicants"><i class="bi bi-people"></i> Applicants</a>
    <a href="#my-team" data-company-nav="my-team"><i class="bi bi-person-badge"></i> My Team</a>
    <a href="#dashboard/messages" data-company-nav="dashboard" data-company-focus="messages" id="sidebarMessagesLink"><i class="bi bi-chat-dots"></i> Messages<% if (messageCount > 0) { %><span class="company-nav-badge"><%= messageCount %></span><% } %></a>
    <a href="#search-workers" data-company-nav="search-workers"><i class="bi bi-search"></i> Search Workers</a>
    <a href="#social-posts" data-company-nav="social-posts"><i class="bi bi-rss"></i> Social Posts</a>
    <a href="#settings" data-company-nav="settings"><i class="bi bi-gear"></i> Settings</a>
  </nav>

  <div class="company-sidebar-profile">
    <div class="company-sidebar-profile-logo"><%= company.initials %></div>
    <div class="company-sidebar-profile-copy">
      <strong><%= company.name %></strong>
      <span><%= company.businessType || 'Construction company' %></span>
      <% if (company.location) { %><span><%= company.location %></span><% } %>
      <span class="company-sidebar-profile-rating"><i class="bi bi-star-fill"></i> <%= company.rating %></span>
    </div>
    <a href="#settings" class="company-sidebar-profile-link" data-company-nav="settings">View Company Profile <i class="bi bi-arrow-right"></i></a>
  </div>
</aside>
