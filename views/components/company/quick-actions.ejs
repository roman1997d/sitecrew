<section class="company-section company-quick-actions" id="post-job">
  <div class="company-section-header company-section-header-compact">
    <h2>Quick Actions</h2>
  </div>

  <div class="company-action-grid company-action-grid-compact">
    <button type="button" class="company-action-card post-job" id="openPostJobModal">
      <i class="bi bi-plus-lg"></i>
      <strong>Post a Job</strong>
    </button>
    <a href="#recommended-workers" class="company-action-card find-workers">
      <i class="bi bi-search"></i>
      <strong>Find Workers</strong>
    </a>
    <button type="button" class="company-action-card post-update" id="openCompanyPostModal">
      <i class="bi bi-megaphone"></i>
      <strong>Post an Update</strong>
    </button>
    <a href="#profile" class="company-action-card view-profile">
      <i class="bi bi-building"></i>
      <strong>View Company Profile</strong>
    </a>
  </div>
</section>
