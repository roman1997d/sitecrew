<section class="company-section company-jobs-section" id="active-jobs">
  <div class="company-panel-head">
    <h2>Active Jobs</h2>
    <a href="#dashboard/active-jobs" class="company-panel-link" data-company-goto="dashboard" data-company-focus="active-jobs">View all jobs</a>
  </div>

  <% if (!jobs.length) { %>
    <article class="company-empty-card">
      <strong>No jobs posted yet</strong>
      <p>Use Post a Job to create your first hiring request.</p>
    </article>
  <% } else { %>
    <div class="company-jobs-table-wrap">
      <table class="company-jobs-table">
        <thead>
          <tr>
            <th>Job Title</th>
            <th>Location</th>
            <th>Applicants</th>
            <th>Status</th>
            <th aria-label="Actions"></th>
          </tr>
        </thead>
        <tbody>
          <% jobs.forEach(function(job) { %>
            <tr
              class="company-job-row"
              data-company-job-card
              data-job-id="<%= job.id %>"
              data-title="<%= job.title %>"
              data-trade-required="<%= job.trade %>"
              data-city="<%= job.city %>"
              data-postcode="<%= job.postcode %>"
              data-rate="<%= job.rate || '' %>"
              data-start-date="<%= job.startDate || '' %>"
              data-duration="<%= job.duration || '' %>"
              data-workers-required="<%= job.workersRequired %>"
              data-description="<%= job.description %>"
              data-certificates-required="<%= job.certificatesRequired %>"
              data-job-status="<%= job.status === 'Open' ? 'open' : 'closed' %>"
            >
              <td>
                <strong class="company-job-title"><%= job.title %></strong>
                <span class="company-job-trade"><%= job.trade %></span>
              </td>
              <td><%= job.location %></td>
              <td>
                <div class="company-job-applicants">
                  <% if (job.applicants > 0) { %>
                    <span class="company-job-applicant-stack" aria-hidden="true">
                      <span></span><span></span><span></span>
                    </span>
                    <span class="company-job-applicant-count"><%= job.applicants %></span>
                  <% } else { %>
                    <span class="company-job-applicant-empty">0</span>
                  <% } %>
                </div>
              </td>
              <td>
                <span class="company-status-pill <%= job.status === 'Open' ? 'open' : 'closed' %>"><%= job.status === 'Open' ? 'Open' : 'In Progress' %></span>
              </td>
              <td class="company-job-menu-cell">
                <details class="company-row-menu">
                  <summary aria-label="Job actions"><i class="bi bi-three-dots"></i></summary>
                  <div class="company-row-menu-panel">
                    <a href="#dashboard/applicants" data-company-goto="dashboard" data-company-focus="applicants">View applicants</a>
                    <button type="button" data-edit-company-job>Edit job</button>
                    <button type="button" data-toggle-company-job><%= job.status === 'Open' ? 'Close request' : 'Reopen request' %></button>
                    <button type="button" class="danger" data-delete-company-job>Delete</button>
                  </div>
                </details>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
