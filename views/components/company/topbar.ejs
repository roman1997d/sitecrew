<header class="company-topbar">
  <div>
    <p>Company workspace</p>
    <h1><%= company.name %></h1>
  </div>

  <div class="company-topbar-metrics" aria-label="Company summary">
    <span><strong><%= insights.activeJobs %></strong> active jobs</span>
    <span><strong><%= insights.workersNeeded %></strong> positions</span>
    <span><strong id="companyAlertsCount"><%= notifications.length %></strong> alerts</span>
  </div>

  <div class="company-topbar-actions">
    <button type="button" id="openCompanyNotifications" aria-label="Notifications" title="Notifications">
      <i class="bi bi-bell"></i>
      <span id="companyNotificationBadge" <%= notifications.length > 0 ? '' : 'hidden' %>><%= notifications.length %></span>
    </button>
    <button type="button" id="openCompanyMessages" aria-label="Messages" title="Messages">
      <i class="bi bi-chat-text"></i>
    </button>
    <button type="button" id="openContactsJournal" aria-label="Contacts" title="Contacts">
      <i class="bi bi-person-lines-fill"></i>
    </button>
    <button type="button" class="company-profile-trigger <%= company.logo ? 'has-logo' : '' %>" aria-label="Profile">
      <% if (company.logo) { %>
        <img src="<%= company.logo %>" alt="<%= company.name %> logo">
      <% } else { %>
        <strong><%= company.initials %></strong>
      <% } %>
    </button>
    <button type="button" class="company-logout-btn" id="companyLogoutBtn" aria-label="Log out" title="Log out">
      <i class="bi bi-box-arrow-right"></i>
    </button>
  </div>
</header>
