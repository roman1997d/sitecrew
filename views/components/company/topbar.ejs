<header class="company-topbar">
  <div class="company-topbar-intro">
    <h1>Welcome back, <%= company.name %></h1>
    <p>Here's what's happening with your projects today.</p>
  </div>

  <div class="company-topbar-tools">
    <label class="company-topbar-search" aria-label="Search dashboard">
      <i class="bi bi-search"></i>
      <input type="search" id="companyTopbarSearch" placeholder="Search anything..." autocomplete="off">
    </label>

    <button type="button" class="company-topbar-bell" id="openCompanyNotifications" aria-label="Notifications">
      <i class="bi bi-bell"></i>
      <span class="company-topbar-bell-dot" id="companyNotificationBadge" <%= notifications.length > 0 ? '' : 'hidden' %>></span>
    </button>

    <button type="button" class="company-topbar-contacts" id="openContactsJournal" aria-label="Contact journal" title="Contact journal">
      <i class="bi bi-person-lines-fill"></i>
    </button>

    <a href="#profile" class="company-topbar-avatar" id="companyTopbarAvatar" aria-label="Company profile">
      <%= company.initials %>
    </a>

    <button type="button" class="company-topbar-logout" id="companyLogoutBtn" aria-label="Log out" title="Log out">
      <i class="bi bi-box-arrow-right"></i>
    </button>
  </div>

  <button type="button" id="openCompanyMessages" hidden aria-hidden="true" tabindex="-1"></button>
</header>
