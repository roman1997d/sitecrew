<%
  const applicantJobTitles = Array.from(new Set(applicants.map((applicant) => applicant.jobTitle))).sort((a, b) => a.localeCompare(b));
%>
<section class="company-section company-applicants-section" id="applicants">
  <div class="company-panel-head">
    <h2>Recent Applicants</h2>
    <% if (applicantJobTitles.length) { %>
      <label class="company-applicant-filter">
        <select id="applicantJobFilter">
          <option value="">All jobs</option>
          <% applicantJobTitles.forEach(function(jobTitle) { %>
            <option value="<%= jobTitle %>"><%= jobTitle %></option>
          <% }); %>
        </select>
      </label>
    <% } else { %>
      <a href="#applicants" class="company-panel-link">View all applicants</a>
    <% } %>
  </div>

  <div class="company-applicant-list">
    <% if (!applicants.length) { %>
      <div class="company-empty-inline">
        <strong>No applicants yet</strong>
        <span>Applicants will appear here after workers apply to your jobs.</span>
      </div>
    <% } %>

    <% applicants.forEach(function(applicant) { %>
      <article class="company-applicant-card" data-application-row data-application-id="<%= applicant.id %>" data-worker-id="<%= applicant.workerId %>" data-job-title="<%= applicant.jobTitle %>">
        <button type="button" class="company-applicant-delete-btn" data-delete-application aria-label="Delete applicant"><i class="bi bi-x-lg"></i></button>

        <div class="company-applicant-card-main">
          <div class="company-worker-avatar"><%= applicant.name.charAt(0) %></div>
          <div class="company-worker-info">
            <strong><%= applicant.name %></strong>
            <span><%= applicant.trade %> · <%= applicant.experience %></span>
            <small>Applied for <strong><%= applicant.jobTitle %></strong><% if (applicant.appliedAgo) { %> · <%= applicant.appliedAgo %><% } %></small>
          </div>
        </div>

        <div class="company-applicant-card-end">
          <span class="company-applicant-rating"><%= applicant.rating %> <i class="bi bi-star-fill"></i></span>
          <button type="button" class="company-review-btn" data-view-worker-profile>Review</button>
        </div>

        <div class="company-row-actions company-applicant-more-actions">
          <button type="button" data-application-action="accepted">Invite</button>
          <button type="button" class="muted" data-application-action="rejected">Reject</button>
          <button type="button" class="contact <%= applicant.savedContact ? 'saved' : '' %>" data-save-applicant-contact <%= applicant.savedContact ? 'disabled' : '' %>><%= applicant.savedContact ? 'Saved' : 'Save' %></button>
          <span class="company-application-status <%= applicant.status %>" data-application-status><%= applicant.status %></span>
        </div>
      </article>
    <% }); %>

    <div class="company-empty-inline" data-applicant-filter-empty hidden>
      <strong>No applicants for this job</strong>
      <span>Choose another job or show all applications.</span>
    </div>
  </div>
</section>
